{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm dev)",
      "Bash(pnpm build)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status)",
      "Bash(git push:*)",
      "Bash(npx drizzle-kit:*)",
      "Edit",
      "Write"
    ],
    "deny": [
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)"
    ]
  }
}