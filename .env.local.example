# ===== Supabase =====
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===== Gemini =====
GOOGLE_API_KEY=
GOOGLE_API_KEY_SECONDARY=

# ===== Perplexity (optional) =====
PERPLEXITY_API_KEY=

# ===== Auth (iron-session) =====
# Random 32+ char string. Generate: openssl rand -hex 32
AUTH_SECRET=
GARFIELD_PASSCODE=
PARTNER_PASSCODE=
TEST_PASSCODE=

# ===== Cron =====
# Random string. Vercel includes this as `Authorization: Bearer ${CRON_SECRET}`.
CRON_SECRET=

# ===== LINE Messaging API (optional, replaces deprecated LINE Notify) =====
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID_GARFIELD=
LINE_USER_ID_PARTNER=

# ===== App =====
NEXT_PUBLIC_APP_URL=http://localhost:3000
TZ=Asia/Bangkok
