# ===== Supabase =====
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===== Gemini =====
GOOGLE_API_KEY=
GOOGLE_API_KEY_SECONDARY=

# ===== Perplexity (optional) =====
PERPLEXITY_API_KEY=

# ===== Moonshot / Kimi (optional, paid last-resort fallback) =====
# When all Gemini tiers fail, callGemini falls through to Kimi.
# Capped at 30 calls/day in lib/llm/models.ts to bound cost.
MOONSHOT_API_KEY=
# Override model id if "kimi-k2.6" isn't the right alias on your account:
# MOONSHOT_MODEL=kimi-k2-0905-preview
# Override base URL for the China endpoint:
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# ===== Auth (iron-session) =====
# Random 32+ char string. Generate: openssl rand -hex 32
AUTH_SECRET=

# ===== Cron =====
# Random string. Vercel includes this as `Authorization: Bearer ${CRON_SECRET}`.
CRON_SECRET=

# ===== LINE Messaging API (optional, replaces deprecated LINE Notify) =====
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID_GARFIELD=
LINE_USER_ID_PARTNER=

# ===== App =====
NEXT_PUBLIC_APP_URL=http://localhost:3000
TZ=Asia/Bangkok
